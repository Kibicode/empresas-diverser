---
import Ubicacion from "../components/pages/contacto/ubicacion.astro";
import BaseLayout from "../layouts/BaseLayout.astro";



---
<BaseLayout>

<section class="bg-white">
    <div class="max-w-7xl mx-auto px-6 py-20 grid gap-12 lg:grid-cols-2">
        <!-- Formulario -->
        <div class="rounded-2xl border p-8 shadow-sm">
            <h2 class="text-2xl font-bold text-slate-900">
                ¿Quieres saber mas de nosotros?
            </h2>

            <p class="mt-2 text-primary-600 text-sm">
                Llena los datos y te contactaremos tan pronto sea posible.
            </p>

            <form
                class="mt-8 space-y-5"
                action="https://formsubmit.co/aseintegspecial@hotmail.com"
                method="POST"
            >
                <div>
                    <label class="block text-sm font-medium text-slate-700">
                        Nombre completo
                    </label>
                    <input
                        name="nombre"
                        type="text"
                        class="mt-1 w-full rounded-xl border px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary-400"
                        placeholder="Ingrese su nombre"
                    />
                </div>

                <div class="grid gap-4 md:grid-cols-2">
                    <div>
                        <label class="block text-sm font-medium text-slate-700">
                            Teléfono
                        </label>
                        <input
                            name="telefono"
                            type="tel"
                            class="mt-1 w-full rounded-xl border px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary-400"
                            placeholder="Número de contacto"
                        />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-slate-700">
                            Correo electrónico
                        </label>
                        <input
                            name="correo"
                            type="email"
                            class="mt-1 w-full rounded-xl border px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary-400"
                            placeholder="correo@empresa.com"
                        />
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700">
                        Tipo de consulta
                    </label>
                    <select
                        name="servicio"
                        class="mt-1 w-full rounded-xl border px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary-400"
                    >
                        <option>Seleccione una opción</option>
                    </select>
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700">
                        Mensaje
                    </label>
                    <textarea
                        name="mensaje"
                        rows="4"
                        class="mt-1 w-full rounded-xl border px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary-400"
                        placeholder="Cuéntenos brevemente su necesidad"
                    ></textarea>
                </div>

                <input type="hidden" name="_captcha" value="false" />
                <!-- <input type="hidden" name="_template" value="table" /> -->
                <input type="hidden" name="_next" value="https://aseinteg.com/gracias" />
                <input type="hidden" name="_honey" style="display:none" />
                <input
                    type="hidden"
                    name="_subject"
                    value="Nuevo contacto desde el sitio web ASEINTEG"
                />

                <button
                    type="submit"
                    class="w-full rounded-3xl bg-primary py-3 font-semibold text-white hover:bg-primary-400 transition"
                >
                    Enviar solicitud
                </button>

                <p class="text-xs text-slate-500 text-center">
                    * No compartimos su información con terceros.
                </p>
            </form>
        </div>

        <!-- Información de contacto -->
        <div>
            <h2 class="text-2xl font-bold text-slate-900">
                Información de contacto
            </h2>

            <ul class="mt-6 space-y-4 text-slate-600 text-sm">
                <li>
                    📍 <strong>Direccion:</strong><br />
                    Diagonal 8 No. 32-07<br />
                    Barrio Blanco – Girardot, Cundinamarca
                </li>

                <li>
                    📱 <strong>Móvil:</strong><br />
                    315 326 3384 · 316 527 9395 · 317 426 9544
                </li>

                <li>
                    ✉️ <strong>Correo:</strong><br />
                    diverser22@gmail.com
                </li>

                <li>
                    🕒 <strong>Horario:</strong><br />
                    
                </li>
            </ul>

            <!-- Legal -->
            <div
                id="map-container"
                class="mt-10 rounded-xl bg-slate-50 p-6 border h-60"
                onclick="openMap()"
            >
                <Ubicacion />
            </div>
        </div>
    </div>
</section>
<script>
    const mapaDiv = document.getElementById("map-container");
    if (mapaDiv) {
        mapaDiv.style.cursor = "pointer";
        mapaDiv.title = "Haga clic para abrir en Google Maps";
        mapaDiv.onclick = function () {
            window.open(
                "https://www.google.com/maps/place/4%C2%B018'26.5%22N+74%C2%B047'58.6%22W/@4.3076335,-74.7994582,19.49z/data=!4m4!3m3!8m2!3d4.307347!4d-74.799607?entry=ttu&g_ep=EgoyMDI2MDEyMS4wIKXMDSoASAFQAw%3D%3D",
                "_blank",
            );
        };
    }
</script>

</BaseLayout>
