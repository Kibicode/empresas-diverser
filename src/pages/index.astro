---

import BaseLayout from "../layouts/BaseLayout.astro";

import { homeData } from "../data/index";
import Cta from "../components/pages/index/Cta.astro";
import Diff from "../components/pages/index/Diff.astro";
import Gallery from "../components/pages/index/Gallery.astro";
import Hero from "../components/pages/index/Hero.astro";
import Programs from "../components/pages/index/Programs.astro";
import Testimonials from "../components/pages/index/Testimonials.astro";


---

<BaseLayout
  title="Centro Educativo Integral en Girardot | Diverser"
  description="Educación inclusiva para niños en fase preescolar. Desarrollo integral, acompañamiento emocional y aprendizaje activo."
>
  <Hero {...homeData.hero} />
  <Diff></Diff>
  <Programs items={homeData.programs} />
  <Testimonials ></Testimonials>
  <Gallery></Gallery>
  <Cta/>
</BaseLayout>
