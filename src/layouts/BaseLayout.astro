---

import Navbar from "../components/commons/Navbar.astro";
import Footer from "../components/commons/Footer.astro";
import WhatsappButton from "../components/commons/Whatsapp_button.astro";
import "../styles/global.css";

const { title, description } = Astro.props;

---

<!doctype html>
<html lang="es">
  <head>
    <!-- 🔤 UTF-8 (IMPORTANTE) -->
    <meta charset="UTF-8" />
    <!-- 🎨 Favicon (opcional) -->
    <link rel="icon" href="/favicon.ico" />
    <!-- Metas -->
    <title>{title}</title>
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <!-- //TODO: QUitar comentario -->
    <!-- <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} /> -->
    <meta name="robots" content="index, follow" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />

    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="bg-bg text-text font-body h-screen">
    <Navbar />
    <main class="relative overflow-hidden">
      <!-- Imagen de fondo -->
      <div
        class="bg-[url('/bg_clips.png')] md:bg-[url('/bg_clips.png  ')]
        fixed inset-0 -z-10 bg-repeat opacity-10"
        aria-hidden="true"
      >
      </div>
      <!-- Contenido -->
      <div class="relative z-10">
        <slot />
      </div>
    </main>
    <Footer />
    <!-- Boton whatsapp -->
    <WhatsappButton />
  </body>
</html>
