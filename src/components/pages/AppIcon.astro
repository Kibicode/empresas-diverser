  ---
const { name, class: className = "w-6 h-6" } = Astro.props;
---

{ name === "brain" && (
  <svg xmlns="http://www.w3.org/2000/svg" class={className} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
    <path d="M9.5 2a3.5 3.5 0 0 0-3.5 3.5v2A3.5 3.5 0 0 0 9.5 11h5A3.5 3.5 0 0 0 18 7.5v-2A3.5 3.5 0 0 0 14.5 2zM6 11v2a3.5 3.5 0 0 0 3.5 3.5h5A3.5 3.5 0 0 0 18 13v-2M9 16v2M15 16v2"/>
  </svg>
)}

{ name === "heart" && (
  <svg xmlns="http://www.w3.org/2000/svg" class={className} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
    <path d="M12 21s-7-4.5-7-10a4 4 0 0 1 7-2 4 4 0 0 1 7 2c0 5.5-7 10-7 10z"/>
  </svg>
)}

{ name === "handshake" && (
  <svg xmlns="http://www.w3.org/2000/svg" class={className} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
    <path d="M4 12l4-4a3 3 0 0 1 4 0l4 4M2 14l6 6M22 14l-6 6"/>
  </svg>
)}

{ name === "eye" && (
  <svg xmlns="http://www.w3.org/2000/svg" class={className} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
    <path d="M1.5 12S5 5.5 12 5.5 22.5 12 22.5 12 19 18.5 12 18.5 1.5 12 1.5 12z"/>
    <circle cx="12" cy="12" r="3"/>
  </svg>
)}

{ name === "graduation-cap" && (
  <svg xmlns="http://www.w3.org/2000/svg" class={className} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
    <path d="M22 10L12 5 2 10l10 5 10-5z"/>
    <path d="M6 12v5c0 1 3 2 6 2s6-1 6-2v-5"/>
  </svg>
)}

{ name === "puzzle" && (
  <svg xmlns="http://www.w3.org/2000/svg" class={className} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
    <path d="M12 2v4a2 2 0 1 1-2 2H6v4a2 2 0 1 1-2 2h4v4h4v-4a2 2 0 1 1 2-2h4v-4h-4a2 2 0 1 1-2-2V2z"/>
  </svg>
)}