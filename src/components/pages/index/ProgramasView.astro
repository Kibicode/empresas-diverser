---
const programas = [
  {
    titulo: "Párvulos",
    edad: "1 a 2 años",
    imagen: "https://picsum.photos/400/300?1",
    color: "primary",
    caracteristicas: ["Estimulación temprana","Desarrollo emocional","Exploración sensorial"]
  },
  {
    titulo: "Pre-jardín",
    edad: "2 a 3 años",
    imagen: "https://picsum.photos/400/300?2",
    color: "accent-pink",
    caracteristicas: ["Lenguaje","Juego guiado","Socialización"]
  },
  {
    titulo: "Jardín",
    edad: "3 a 4 años",
    imagen: "https://picsum.photos/400/300?3",
    color: "accent-yellow",
    caracteristicas: ["Creatividad","Autonomía","Trabajo en grupo"]
  },
  {
    titulo: "Transición",
    edad: "4 a 5 años",
    imagen: "https://picsum.photos/400/300?4",
    color: "success",
    caracteristicas: ["Lectoescritura","Lógica","Preparación escolar"]
  }
];

const extras = [
  { titulo: "Música", icono: "music_note", color: "primary", descripcion: "Expresión y ritmo" },
  { titulo: "Arte", icono: "palette", color: "accent-pink", descripcion: "Creatividad libre" },
  { titulo: "Psicomotricidad", icono: "sports_gymnastics", color: "accent-yellow", descripcion: "Desarrollo físico" },
  { titulo: "Inglés", icono: "language", color: "success", descripcion: "Aprendizaje natural" }
];

const detalle = [
  {
    titulo: "Párvulos",
    edad: "1 a 2 años",
    imagen: "https://picsum.photos/600/400?11",
    descripcion: "Acompañamos los primeros descubrimientos desde el afecto, la seguridad y el vínculo emocional.",
    bullets: ["Adaptación progresiva","Exploración sensorial","Acompañamiento cercano"]
  },
  {
    titulo: "Pre-jardín",
    edad: "2 a 3 años",
    imagen: "https://picsum.photos/600/400?12",
    descripcion: "Impulsamos la comunicación, la curiosidad y la interacción con el entorno.",
    bullets: ["Lenguaje","Juego guiado","Socialización"]
  },
  {
    titulo: "Actividades extracurriculares",
    edad: "Después de clase",
    imagen: "https://picsum.photos/600/400?13",
    descripcion: "Espacios para descubrir talentos, fortalecer habilidades y disfrutar aprendiendo.",
    bullets: ["Arte","Música","Movimiento","Inglés"]
  }
];
---

<!-- HERO -->
<section class="bg-white py-20 text-center">
  <div class="max-w-3xl mx-auto px-6">
    <h1 class="text-4xl font-heading text-primary font-bold">
      Programas y experiencias
    </h1>
    <p class="mt-4 text-text/80">
      Cada etapa es una oportunidad para crecer, explorar y aprender con amor.
    </p>
  </div>
</section>

<!-- DIVIDER -->
<div class="h-[1px] bg-gradient-to-r from-transparent via-primary/20 to-transparent"></div>

<!-- PROGRAMAS -->
<section class="bg-bg py-20">
  <div class="max-w-6xl mx-auto px-6">

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-10">

      {
        programas.map((p) => (
          <div class="relative group">

            <!-- 📎 CLIP -->
            <div class={`absolute -top-8 left-1/2 -translate-x-1/2 w-12 h-16 text-${p.color} rotate-12`}>
              <svg class="w-full h-full" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path d="M21.44 11.05l-9.19 9.19a6 6 0 01-8.49-8.49l9.19-9.19a4 4 0 015.66 5.66l-9.2 9.19a2 2 0 01-2.83-2.83l8.49-8.48"/>
              </svg>
            </div>

            <div class="bg-white rounded-3xl shadow-xl overflow-hidden group-hover:-translate-y-2 transition">

              <div class="h-52 overflow-hidden">
                <img src={p.imagen} class="w-full h-full object-cover group-hover:scale-110 transition"/>
              </div>

              <div class="p-6 text-center">
                <h3 class="font-bold">{p.titulo}</h3>
                <p class="text-sm text-text/60 italic">{p.edad}</p>

                <ul class="mt-4 text-sm text-left space-y-2">
                  {p.caracteristicas.map((c) => (
                    <li class="flex gap-2">
                      <span class={`w-2 h-2 rounded-full bg-${p.color}`}></span>{c}
                    </li>
                  ))}
                </ul>
              </div>

            </div>

          </div>
        ))
      }

    </div>
  </div>
</section>

<!-- DIVIDER -->
<div class="h-[1px] bg-gradient-to-r from-transparent via-primary/20 to-transparent"></div>

<!-- EXTRAS -->
<section class="bg-white py-20 relative overflow-hidden">
  
  <div class="absolute inset-0 opacity-5">
    <img src="https://picsum.photos/1200/800?blur=3" class="w-full h-full object-cover"/>
  </div>

  <div class="relative max-w-6xl mx-auto px-6">

    <div class="text-center">
      <h2 class="text-3xl font-heading text-primary font-bold">
        Actividades extracurriculares
      </h2>
    </div>

    <div class="mt-12 grid md:grid-cols-2 lg:grid-cols-4 gap-10">
      {
        extras.map((e) => (
          <div class="bg-bg p-6 rounded-2xl text-center shadow-md group hover:-translate-y-2 transition">

            <div class={`w-14 h-14 mx-auto rounded-full flex items-center justify-center bg-${e.color}/10 text-${e.color}`}>
              <span class="material-symbols-outlined">{e.icono}</span>
            </div>

            <h3 class="mt-4 font-semibold">{e.titulo}</h3>
            <p class="text-sm text-text/70">{e.descripcion}</p>

          </div>
        ))
      }
    </div>

  </div>
</section>

<!-- DIVIDER -->
<div class="h-[1px] bg-gradient-to-r from-transparent via-primary/20 to-transparent"></div>

<!-- ZIG ZAG -->
<section class="bg-bg py-24">
  <div class="max-w-6xl mx-auto px-6 space-y-24">

    {
      detalle.map((item, i) => {
        const reverse = i % 2 !== 0;

        return (
          <div class="grid md:grid-cols-2 gap-12 items-center">

            <!-- IMAGEN -->
            <div class={`relative group ${reverse ? "md:order-2" : ""}`}>
              <div class="absolute -top-6 left-1/2 -translate-x-1/2 w-12 h-16 text-primary rotate-12 z-10">
                <svg class="w-full h-full" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path d="M21.44 11.05l-9.19 9.19a6 6 0 01-8.49-8.49l9.19-9.19a4 4 0 015.66 5.66l-9.2 9.19a2 2 0 01-2.83-2.83l8.49-8.48"/>
                </svg>
              </div>

              <img src={item.imagen}
                   class="rounded-3xl shadow-xl h-[350px] w-full object-cover group-hover:scale-105 transition"/>
            </div>

            <!-- TEXTO -->
            <div class={`${reverse ? "md:order-1" : ""}`}>
              <p class="text-primary text-sm font-semibold">{item.edad}</p>
              <h3 class="text-2xl font-bold mt-2">{item.titulo}</h3>

              <p class="mt-4 text-text/80">{item.descripcion}</p>

              <ul class="mt-6 space-y-2 text-sm">
                {item.bullets.map((b) => (
                  <li class="flex gap-2">
                    <span class="w-2 h-2 bg-primary rounded-full"></span>{b}
                  </li>
                ))}
              </ul>
            </div>

          </div>
        );
      })
    }

  </div>
</section>

<!-- CTA FINAL -->
<section class="bg-primary py-20 text-center text-white">
  <div class="max-w-xl mx-auto px-6">

    <h3 class="text-3xl font-bold">
      ¿Listo para comenzar esta etapa?
    </h3>

    <p class="mt-4 text-white/80">
      Agenda una visita y descubre el espacio ideal para tu hijo.
    </p>

    <a href="https://wa.me/57XXXXXXXXXX"
       class="mt-6 inline-block bg-white text-primary px-6 py-3 rounded-xl font-semibold
              hover:scale-105 transition">
      Agendar visita
    </a>

  </div>
</section>