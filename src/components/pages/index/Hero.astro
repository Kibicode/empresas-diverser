---
interface Props {
    title: string;
    subtitle: string;
    image_desktop: string;
    image_mobile?: string;
}

const { image_desktop, image_mobile } = Astro.props;
---

<!-- Simplified Hero Section -->
<main class="relative h-screen w-full max-h-[calc(100vh-5em)] flex items-end pt-20">
  <!-- Background Layer -->
  <div class="absolute inset-0 -z-10">
    <picture>
      {image_mobile && <source media="(max-width: 768px)" srcset={image_mobile} />}
      <img
        alt="Modern high-end school library"
        class="w-full h-[calc(100vh-5em)] object-cover md:object-cover"
        src={image_desktop}
      />
    </picture>
  </div>
  <!-- Content Area -->
  <div
    class="container mx-auto pb-16 md:pb-24 flex flex-col md:flex-row justify-between items-end gap-12 relative"
  >
  </div>
</main>
