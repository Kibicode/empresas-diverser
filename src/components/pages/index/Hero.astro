---
interface Props {
    title: string;
    subtitle: string;
    image: string;
  
}

const { title, subtitle, image } = Astro.props;
---

<!-- Simplified Hero Section -->
<main class="relative h-screen w-full max-h-[calc(100vh-5em)] flex items-end pt-20">
  <!-- Background Layer -->
  <div class="absolute inset-0 -z-10">
    <img
      alt="Modern high-end school library"
      class="w-full h-[calc(100vh-5em)] object-center md:object-cover"
      src={image}
    />
  </div>
  <!-- Content Area -->
  <div
    class="container mx-auto pb-16 md:pb-24 flex flex-col md:flex-row justify-between items-end gap-12 relative"
  >
    <!-- Left: Floating Content Card -->
    <div
      class="max-w-lg md:max-w-2xl bg-white/60 backdrop-blur-xl p-8 mx-10 -my-6 md:-my-10  md:p-10 rounded-3xl shadow-3xl relative -rotate-6"
    >
      <!-- Decorative Paperclip SVG -->
      <div
        class="absolute -top-6 -right-4 z-20 w-12 h-16 rotate-12 text-accent-pink"
      >
        <svg
          class="w-full h-full"
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="1.5"
          viewbox="0 0 24 24"
        >
          <path
            d="M21.44 11.05l-9.19 9.19a6 6 0 01-8.49-8.49l9.19-9.19a4 4 0 015.66 5.66l-9.2 9.19a2 2 0 01-2.83-2.83l8.49-8.48"
          ></path>
        </svg>
      </div>
      <h1
        class="font-headline font-extrabold text-2xl md:text-4xl text-primary leading-tight mb-6"
      >
        {title}
      </h1>
      <p
        class="text-slate-700 text-xl md:text-xl font-medium leading-relaxed max-w-lg mb-8"
      >
        {subtitle}
      </p>
    </div>
  </div>
</main>
