---
import { testimoniales } from "../../../data";
import TestimonialCard from "../TestimonialCard.astro";

const shuffled = [...testimoniales].sort(() => Math.random() - 0.5);
const mobileItems = shuffled.slice(0, 3);
---

<section class="bg-bg py-20">
  <div class="max-w-6xl mx-auto px-6 text-center">
    <!-- Título -->
    <h2 class="text-3xl md:text-4xl font-heading text-primary font-bold">
      Así nos ven las familias
    </h2>

    <p class="mt-4 text-text/80 max-w-2xl mx-auto">
      Un reflejo del amor, el cuidado y el compromiso.
    </p>
    <p class="text-sm text-text/60">
      Testimonios anónimos compartidos por familias de nuestra comunidad
    </p>

    <!-- MOBILE (solo 3) -->
    <div class="mt-16 grid gap-10 md:hidden">
      {
        mobileItems.map((testimonial, i) => (
          <TestimonialCard
            calificacion={testimonial.calificacion}
            nombre={testimonial.nombre}
            comentario={testimonial.comentario}
            titulo={testimonial.titulo}
            index={i}
          />
        ))
      }
    </div>

    <!-- DESKTOP (todos) -->
    <div class="mt-16 hidden md:grid gap-10 md:grid-cols-3">
      {
        testimoniales.map((testimonial, i) => (
          <TestimonialCard
            calificacion={testimonial.calificacion}
            nombre={testimonial.nombre}
            comentario={testimonial.comentario}
            titulo={testimonial.titulo}
            index={i}
          />
        ))
      }
    </div>
  </div>
</section>
