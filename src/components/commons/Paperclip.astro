---
const { color = "text-primary", rotate = "-rotate-12", index = 0 } = Astro.props;
import { colors } from '../../data/home.ts'

const importedColor = `${colors[index]}`;
---

<div class={`absolute -top-8 left-1/2 -translate-x-1/2 z-30 w-10 h-14 ${rotate}`} style={`color: ${importedColor};`}>
  <svg
    class="w-full h-full"
    fill="none"
    stroke="currentColor"
    stroke-linecap="round"
    stroke-linejoin="round"
    stroke-width="1.5"
    viewBox="0 0 24 24"
  >
    <path d="M21.44 11.05l-9.19 9.19a6 6 0 01-8.49-8.49l9.19-9.19a4 4 0 015.66 5.66l-9.2 9.19a2 2 0 01-2.83-2.83l8.49-8.48"></path>
  </svg>
</div>