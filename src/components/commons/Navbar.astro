---
import { pages } from "../../data/site";
---

<header
  class="fixed top-0 left-0 w-full z-50
         bg-white/80 backdrop-blur-md
         border-b border-slate-200"
>
  <div
    class="max-w-7xl mx-auto px-6 h-20
           flex items-center justify-between relative"
  >
    <!-- Logo -->
    <a class="flex items-center gap-4 group" href="/">
      <img
        class="w-20 h-20 object-contain transition-transform duration-300 group-hover:scale-105"
        src="/index/navbar_logo.png"
        alt="Diverser logo"
      />
    </a>

    <!-- NAV DESKTOP -->
    <nav class="hidden md:flex items-center gap-8">
      {
        pages.map((page) => (
          <a
            href={page.path}
            class="relative flex items-center gap-2 text-sm font-semibold text-slate-600 
                   hover:text-primary transition-all duration-300 group"
          >
            <span
              class="material-symbols-outlined text-base opacity-70 
                     group-hover:opacity-100 group-hover:-translate-y-[1px]
                     transition"
            >
              {page.icon}
            </span>

            {page.name}

            <span
              class="absolute -bottom-1 left-0 w-0 h-[2px] bg-primary 
                     group-hover:w-full transition-all duration-300"
            />
          </a>
        ))
      }
    </nav>

    <!-- MOBILE -->
    <div class="md:hidden flex items-center">
      <input class="peer hidden" id="menu-toggle" type="checkbox" />

      <label
        class="cursor-pointer p-2 rounded-lg hover:bg-slate-100 transition z-[60]"
        for="menu-toggle"
      >
        <span class="material-symbols-outlined text-3xl">menu</span>
      </label>

      <!-- Drawer -->
      <div
        class="fixed inset-0 bg-white z-[55]
               opacity-0 invisible
               peer-checked:opacity-100 peer-checked:visible
               transition-all duration-300
               flex flex-col pt-24 px-8"
      >
        <!-- Close -->
        <label
          class="absolute top-6 right-6 cursor-pointer z-[60]"
          for="menu-toggle"
        >
          <span class="material-symbols-outlined text-4xl">close</span>
        </label>

        <nav class="flex flex-col gap-6 text-lg font-semibold">
          {
            pages.map((page) => (
              <a
                href={page.path}
                class="flex items-center gap-3 border-b pb-4 text-slate-700 
                       hover:text-primary transition"
              >
                <span class="material-symbols-outlined">{page.icon}</span>
                {page.name}
              </a>
            ))
          }
        </nav>
      </div>
    </div>
  </div>
</header>

<!-- 🔥 IMPORTANTE: compensar altura del navbar -->
<div class="h-20"></div>
