---
import { pages } from "../../data/site";

---

<header
  class="sticky top-0 z-50 w-full bg-white border-b border-slate-200 overflow-visible"
>

  <div
    class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between relative"
  >
    <!-- Logo -->
    <a class="flex items-center gap-4 group" href="/">
      <!-- <div class="border-l border-slate-200 pl-4">
        <h1
          class="text-lg font-extrabold tracking-tight text-primary uppercase"
        >
          DIVERSER
        </h1>
        <p
          class="text-[10px] font-bold text-secondary uppercase tracking-widest"
        >
          Jardin Infantil y Preescolar
        </p>
      </div> -->
      <img class="w-56 h-16 object-fill" src="/index/navbar_logo.png" alt="">
    </a>

    <!-- NAV DESKTOP -->
    <nav class="hidden md:flex items-center gap-6">
      {
        pages.map((page) => (
          <a
            href={page.path}
            class="relative flex items-center gap-2 text-sm font-bold text-slate-600 
                   hover:text-primary transition-all duration-300 group"
          >
            <span
              class="material-symbols-outlined text-base opacity-70 
                         group-hover:opacity-100 group-hover:-translate-y-[1px]
                         transition"
            >
              {page.icon}
            </span>

            {page.name}

            <span
              class="absolute -bottom-1 left-0 w-0 h-[2px] bg-primary 
                         group-hover:w-full transition-all duration-300"
            />
          </a>
        ))
      }
    </nav>

    <!-- MOBILE -->
    <div class="md:hidden flex items-center">
      <input class="peer hidden" id="menu-toggle" type="checkbox" />

      <label
        class="cursor-pointer p-2 rounded-lg hover:bg-surface transition z-[50]"
        for="menu-toggle"
      >
        <span class="material-symbols-outlined text-3xl">menu</span>
      </label>

      <!-- Drawer -->
      <div
        class="fixed inset-0 bg-white
               opacity-0 invisible
               peer-checked:opacity-100 peer-checked:visible
               transition-all duration-300
               z-[60] flex flex-col pt-24 px-8 h-dvh"
      >
        <label
          class="absolute top-6 right-6 cursor-pointer z-[60]"
          for="menu-toggle"
        >
          <span class="material-symbols-outlined text-4xl">close</span>
        </label>

        <nav class="flex flex-col gap-6 text-lg font-bold">
          {
            pages.map((page) => (
              <a
                href={page.path}
                class="flex items-center gap-3 border-b pb-4 text-text 
                       hover:text-primary transition"
              >
                <span class="material-symbols-outlined">{page.icon}</span>

                {page.name}
              </a>
            ))
          }
        </nav>
      </div>
    </div>
  </div>
</header>
